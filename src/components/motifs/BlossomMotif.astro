---
interface Props {
  class?: string;
  width?: number;
}

const { class: className = '', width = 80 } = Astro.props;

const clusters = [
  { cx: 20, cy: 24, scale: 1 },
  { cx: 52, cy: 44, scale: 0.7 },
  { cx: 34, cy: 60, scale: 0.5 },
];

function petalPoints(cx: number, cy: number, r: number) {
  return Array.from({ length: 5 }, (_, i) => {
    const angle = (Math.PI * 2 * i) / 5 - Math.PI / 2;
    return {
      x: cx + Math.cos(angle) * r,
      y: cy + Math.sin(angle) * r,
    };
  });
}
---

<svg
  class:list={['motif blossom-motif', className]}
  width={width}
  viewBox="0 0 80 80"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  {clusters.map((c) => (
    <g opacity={0.85 * c.scale + 0.15}>
      {petalPoints(c.cx, c.cy, 6 * c.scale).map((p) => (
        <circle cx={p.x} cy={p.y} r={4 * c.scale} fill="var(--color-accent-secondary)" opacity="0.5" />
      ))}
      <circle cx={c.cx} cy={c.cy} r={2.2 * c.scale} fill="var(--color-accent)" />
    </g>
  ))}
</svg>

<style>
  .blossom-motif {
    height: auto;
    filter: drop-shadow(var(--glow-accent));
  }
</style>
