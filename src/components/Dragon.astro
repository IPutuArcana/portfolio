---
// An original sky-serpent that weaves between the cards of the page.
//
// The body is not hand-drawn: src/scripts/dragon.ts measures the real card
// positions, threads a spline between them, and writes the outline into the
// two paths below. Two layers are used so the serpent reads as *coiling*:
// the long back layer paints behind the cards (z-index -1), while the neck and
// head come forward on top of them.
---

<svg
  id="dragon-back"
  class="dragon-layer dragon-layer--back"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="none"
>
  <defs>
    <!-- User-space + reflect, so the shading repeats every ~34px along the body
         instead of being stretched flat across the whole 4000px document. -->
    <linearGradient
      id="dragon-scale"
      gradientUnits="userSpaceOnUse"
      x1="0"
      y1="0"
      x2="10"
      y2="34"
      spreadMethod="reflect"
    >
      <stop offset="0%" stop-color="var(--dragon-scale-hi)" />
      <stop offset="55%" stop-color="var(--dragon-scale-mid)" />
      <stop offset="100%" stop-color="var(--dragon-scale-lo)" />
    </linearGradient>

    <!-- The head is small enough that the bounding-box gradient still reads. -->
    <linearGradient id="dragon-scale-head" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0%" stop-color="var(--dragon-scale-hi)" />
      <stop offset="55%" stop-color="var(--dragon-scale-mid)" />
      <stop offset="100%" stop-color="var(--dragon-scale-lo)" />
    </linearGradient>

    <linearGradient id="dragon-fin-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="var(--dragon-fin-hi)" />
      <stop offset="100%" stop-color="var(--dragon-fin-lo)" />
    </linearGradient>

    <radialGradient id="dragon-eye-grad" cx="0.42" cy="0.38" r="0.7">
      <stop offset="0%" stop-color="var(--dragon-eye-hi)" />
      <stop offset="100%" stop-color="var(--dragon-eye-lo)" />
    </radialGradient>

    <!-- Measured, never painted: the spine the outline is sampled from. -->
    <path id="dragon-spine" fill="none" stroke="none"></path>
  </defs>

  <g data-fins-back></g>
  <path class="dragon-body" data-body-back></path>
</svg>

<svg
  id="dragon-front"
  class="dragon-layer dragon-layer--front"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="none"
>
  <g data-fins-front></g>
  <path class="dragon-body" data-body-front></path>

  <g data-head class="dragon-head">
    <g data-head-flip>
      <!-- Swept-back horns and a single crest, drawn behind the skull. -->
      <path class="dragon-horn" d="M -24 -15 C -34 -26 -50 -33 -64 -30 C -52 -23 -36 -13 -26 -7 Z"></path>
      <path class="dragon-horn" d="M -28 -5 C -40 -11 -55 -14 -66 -9 C -54 -5 -40 -1 -29 2 Z"></path>
      <path class="dragon-crest" d="M -20 -21 L -27 -40 L -5 -25 Z"></path>

      <!-- Barbels trail backwards from the chin, like a swimming serpent's. -->
      <path class="dragon-barbel" d="M 30 7 C 27 22 13 33 -4 35"></path>
      <path class="dragon-barbel" d="M 23 9 C 21 25 7 37 -11 41"></path>

      <!-- Lower jaw: hinged at the back so Fase 4 can open it. -->
      <g class="dragon-jaw" data-jaw>
        <path class="dragon-jaw-shape" d="M -30 2 L 39 2 L 39 6 C 16 15 -10 16 -30 9 Z"></path>
        <path class="dragon-tooth" d="M 30 5 L 31.5 10 L 27 5 Z"></path>
      </g>

      <!-- Upper skull: brow ridge over the eye, long tapering snout. -->
      <path
        class="dragon-skull"
        d="M -34 -2 C -34 -18 -20 -26 -6 -24 C 8 -22 24 -15 36 -7 L 41 -3 L 41 2 L -34 4 Z"
      ></path>
      <path class="dragon-snout-ridge" d="M -4 -21 C 10 -18 25 -12 35 -5"></path>
      <path class="dragon-tooth" d="M 31 1 L 32.5 6 L 28 1 Z"></path>

      <!-- Nostril + eye. -->
      <ellipse class="dragon-nostril" cx="33" cy="-4" rx="2.4" ry="1.5"></ellipse>
      <g class="dragon-eye-group">
        <ellipse class="dragon-eye" cx="-10" cy="-13" rx="6.5" ry="5.5"></ellipse>
        <ellipse class="dragon-pupil" cx="-9" cy="-13" rx="1.8" ry="4.6"></ellipse>
        <circle class="dragon-glint" cx="-12" cy="-15" r="1.5"></circle>
      </g>
      <path class="dragon-brow" d="M -19 -19 C -13 -23 -5 -23 1 -20"></path>
    </g>
  </g>
</svg>

<style>
  .dragon-layer {
    --dragon-scale-hi: oklch(74% 0.16 152);
    --dragon-scale-mid: oklch(58% 0.16 158);
    --dragon-scale-lo: oklch(40% 0.12 168);
    --dragon-fin-hi: oklch(88% 0.16 95);
    --dragon-fin-lo: oklch(70% 0.18 78);
    --dragon-eye-hi: oklch(88% 0.17 85);
    --dragon-eye-lo: oklch(60% 0.22 35);

    position: absolute;
    top: 0;
    left: 0;
    overflow: visible;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.2s var(--ease-out-expo);
  }

  /* Behind every card, but still above the fixed backdrop. */
  .dragon-layer--back {
    z-index: -1;
  }

  .dragon-layer--back.is-ready {
    opacity: 0.62;
  }

  /* The neck and head ride over the cards. */
  .dragon-layer--front {
    z-index: 14;
  }

  .dragon-layer--front.is-ready {
    opacity: 1;
  }

  .dragon-body {
    fill: url(#dragon-scale);
    stroke: oklch(30% 0.08 165 / 0.45);
    stroke-width: 1;
    stroke-linejoin: round;
  }

  /* Fins are created by dragon.ts, so they never carry Astro's scoping
     attribute — this rule has to be global to reach them. */
  :global(.dragon-fin) {
    fill: var(--dragon-fin-hi, oklch(88% 0.16 95));
    stroke: oklch(45% 0.14 80 / 0.5);
    stroke-width: 0.75;
    stroke-linejoin: round;
  }

  /* ---------- Head ---------- */
  .dragon-skull {
    fill: url(#dragon-scale-head);
    stroke: oklch(30% 0.08 165 / 0.5);
    stroke-width: 1.1;
    stroke-linejoin: round;
  }

  .dragon-jaw-shape {
    fill: oklch(50% 0.13 165);
    stroke: oklch(28% 0.07 165 / 0.55);
    stroke-width: 1;
    stroke-linejoin: round;
  }

  .dragon-jaw {
    transform-box: fill-box;
    transform-origin: 4% 20%;
    transform: rotate(var(--jaw, 0deg));
    transition: transform 320ms var(--ease-out-expo);
  }

  .dragon-horn,
  .dragon-crest {
    fill: url(#dragon-fin-grad);
    stroke: oklch(45% 0.14 80 / 0.45);
    stroke-width: 0.8;
    stroke-linejoin: round;
  }

  .dragon-barbel {
    fill: none;
    stroke: var(--dragon-fin-lo);
    stroke-width: 2.4;
    stroke-linecap: round;
    transform-box: fill-box;
    transform-origin: 0% 0%;
    animation: barbel-drift 4.5s ease-in-out infinite;
  }

  .dragon-barbel + .dragon-barbel {
    animation-delay: -1.6s;
  }

  .dragon-snout-ridge,
  .dragon-brow {
    fill: none;
    stroke: oklch(34% 0.1 165 / 0.7);
    stroke-width: 1.8;
    stroke-linecap: round;
  }

  .dragon-tooth {
    fill: oklch(97% 0.02 100);
  }

  .dragon-nostril {
    fill: oklch(28% 0.06 165 / 0.8);
  }

  .dragon-eye {
    fill: url(#dragon-eye-grad);
    filter: drop-shadow(0 0 5px var(--dragon-eye-lo));
    transform-box: fill-box;
    transform-origin: center;
    animation: eye-pulse 3.4s ease-in-out infinite;
  }

  .dragon-pupil {
    fill: oklch(16% 0.03 300);
  }

  .dragon-glint {
    fill: oklch(100% 0 0 / 0.9);
  }

  .dragon-eye-group {
    transform-box: fill-box;
    transform-origin: center;
    animation: dragon-blink 6.5s ease-in-out infinite;
  }

  @keyframes dragon-blink {
    0%,
    93%,
    100% {
      transform: scaleY(1);
    }
    96% {
      transform: scaleY(0.1);
    }
  }

  @keyframes eye-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.72;
    }
  }

  @keyframes barbel-drift {
    0%,
    100% {
      transform: rotate(-5deg);
    }
    50% {
      transform: rotate(6deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dragon-barbel,
    .dragon-eye,
    .dragon-eye-group {
      animation: none;
    }
  }
</style>

<script src="../scripts/dragon.ts"></script>
