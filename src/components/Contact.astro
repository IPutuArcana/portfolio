---
import { content, type Lang } from '../data/content';
import CloudMotif from './motifs/CloudMotif.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = content[lang];
const en = content.en;
const id = content.id;
---

<section class="section wrap" id="contact">
  <CloudMotif class="contact-cloud" width={240} tone="accent" />
  <div class="contact-grid">
    <div class="contact-info panel reveal">
      <span class="eyebrow" data-i18n-id={id.contact.eyebrow} data-i18n-en={en.contact.eyebrow}>{t.contact.eyebrow}</span>
      <h2 data-i18n-id={id.contact.heading} data-i18n-en={en.contact.heading}>{t.contact.heading}</h2>
      <p class="contact-body" data-i18n-id={id.contact.body} data-i18n-en={en.contact.body}>{t.contact.body}</p>
      <a href={`mailto:${t.contact.email}`} class="contact-email">{t.contact.email}</a>
    </div>

    <ul class="social-links reveal">
      <li>
        <a class="panel" href="https://github.com/IPutuArcana" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
          </svg>
          <span>GitHub</span>
        </a>
      </li>
      <li>
        <a class="panel" href="https://instagram.com/aznt.v1" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          <span>Instagram</span>
        </a>
      </li>
    </ul>
  </div>
</section>

<style>
  #contact {
    position: relative;
  }

  .contact-cloud {
    bottom: -1rem;
    left: -3rem;
  }

  .contact-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-info {
    padding: var(--space-lg);
  }

  .contact-grid h2 {
    font-size: var(--text-h2);
    margin-block: var(--space-xs) var(--space-md);
  }

  .contact-body {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-bottom: var(--space-md);
  }

  .contact-email {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--text-h3);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 6px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out-expo);
  }

  .contact-email:hover {
    text-decoration-color: var(--color-accent);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: border-color var(--duration-fast) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }

  .social-links a:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
  }

  .social-links svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
