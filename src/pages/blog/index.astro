---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import CloudMotif from '../../components/motifs/CloudMotif.astro';
import { content } from '../../data/content';

const lang = 'id' as const;
const t = content[lang];
const en = content.en;
const id = content.id;
---

<BaseLayout lang={lang}>
  <Header lang={lang} transition:persist />
  <main>
    <section class="section wrap" id="main">
      <CloudMotif class="blog-cloud" width={240} />
      <div class="blog-head panel reveal">
        <span class="eyebrow" data-i18n-id={id.blog.eyebrow} data-i18n-en={en.blog.eyebrow}>{t.blog.eyebrow}</span>
        <h1 data-i18n-id={id.blog.heading} data-i18n-en={en.blog.heading}>{t.blog.heading}</h1>
        <p class="note" data-i18n-id={id.blog.note} data-i18n-en={en.blog.note}>{t.blog.note}</p>
      </div>

      <div class="blog-grid">
        {t.blog.posts.map((post, i) => (
          <BlogPostCard post={post} enPost={en.blog.posts[i]} />
        ))}
      </div>
    </section>
  </main>
  <Footer lang={lang} transition:persist />
</BaseLayout>

<style>
  #main {
    position: relative;
    padding-block: var(--space-xl) var(--space-section);
  }

  .blog-cloud {
    top: -1rem;
    right: -3rem;
    z-index: 0;
  }

  .blog-head {
    position: relative;
    z-index: 1;
    padding: var(--space-lg);
    max-width: 38rem;
  }

  .blog-head h1 {
    font-size: var(--text-h2);
    margin-block: var(--space-xs) var(--space-sm);
  }

  .note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  @media (max-width: 800px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
